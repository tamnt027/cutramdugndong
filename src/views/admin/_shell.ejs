<%- include('_head') %>
<div class="flex flex-col lg:flex-row min-h-screen">
  <!-- Sidebar -->
  <aside class="lg:w-64 bg-forest-900 text-cream-100 lg:min-h-screen flex-shrink-0">
    <div class="p-5 border-b border-forest-800 flex items-center justify-between">
      <a href="/admin" class="flex items-center gap-3">
        <div class="w-10 h-10 rounded-full bg-earth-500 flex items-center justify-center font-bold">DĐ</div>
        <div>
          <div class="font-bold">Dũng Đông</div>
          <div class="text-xs text-cream-200">Admin panel</div>
        </div>
      </a>
      <button id="adm-menu" class="lg:hidden p-2" aria-label="Menu">
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/></svg>
      </button>
    </div>
    <nav id="adm-nav" class="hidden lg:block p-3 space-y-1">
      <% const items = [
        { href: '/admin', label: 'Tổng quan', key: 'dashboard', icon: 'M3 12l2-2 7-7 7 7 2 2v8a2 2 0 01-2 2h-3a1 1 0 01-1-1v-4a1 1 0 00-1-1h-2a1 1 0 00-1 1v4a1 1 0 01-1 1H5a2 2 0 01-2-2v-8z' },
        { href: '/admin/news', label: 'Tin tức', key: 'news', icon: 'M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9a2 2 0 00-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z' },
        { href: '/admin/activities', label: 'Hoạt động', key: 'activities', icon: 'M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z' },
        { href: '/admin/contacts', label: 'Yêu cầu báo giá', key: 'contacts', icon: 'M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z' },
      ]; %>
      <% items.forEach(function(it) { %>
        <a href="<%= it.href %>" class="flex items-center gap-3 px-3 py-2.5 rounded-md text-sm font-medium transition <%= section === it.key ? 'bg-forest-700 text-white' : 'text-cream-200 hover:bg-forest-800 hover:text-white' %>">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="<%= it.icon %>"/></svg>
          <%= it.label %>
        </a>
      <% }); %>
      <div class="pt-3 mt-3 border-t border-forest-800 space-y-1">
        <a href="/" target="_blank" class="flex items-center gap-3 px-3 py-2.5 rounded-md text-sm font-medium text-cream-200 hover:bg-forest-800 hover:text-white">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/></svg>
          Xem trang web
        </a>
        <form method="POST" action="/admin/logout">
          <button type="submit" class="w-full flex items-center gap-3 px-3 py-2.5 rounded-md text-sm font-medium text-cream-200 hover:bg-red-900 hover:text-white transition">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"/></svg>
            Đăng xuất
          </button>
        </form>
      </div>
    </nav>
  </aside>

  <!-- Main -->
  <div class="flex-1 min-w-0">
    <header class="bg-white border-b border-earth-100 px-4 sm:px-6 py-4 flex items-center justify-between">
      <h1 class="font-bold text-xl text-forest-900"><%= title %></h1>
      <% if (typeof headerActions !== 'undefined') { %><div><%- headerActions %></div><% } %>
    </header>

    <% if (locals.flash) { %>
      <div class="mx-4 sm:mx-6 mt-4 bg-forest-50 border border-forest-200 text-forest-800 px-4 py-3 rounded-md text-sm">
        <%= flash.message %>
      </div>
    <% } %>

    <div class="p-4 sm:p-6">

<%- include('_head') %>
<div class="min-h-screen flex items-center justify-center px-4 bg-gradient-to-br from-forest-800 to-forest-950">
  <div class="w-full max-w-md">
    <div class="text-center mb-8">
      <div class="w-16 h-16 mx-auto rounded-full bg-earth-500 flex items-center justify-center font-bold text-white text-2xl mb-4">DĐ</div>
      <h1 class="text-cream-50 text-2xl font-bold">Quản trị Dũng Đông</h1>
      <p class="text-cream-200 text-sm mt-1">Đăng nhập để quản lý nội dung</p>
    </div>
    <form method="POST" action="/admin/login" class="bg-white rounded-2xl p-6 sm:p-8 shadow-2xl">
      <% if (error) { %>
        <div class="mb-4 bg-red-50 border border-red-200 text-red-800 px-4 py-3 rounded-md text-sm">Sai tài khoản hoặc mật khẩu.</div>
      <% } %>
      <div class="mb-4">
        <label class="block text-sm font-semibold text-forest-900 mb-1.5">Tài khoản</label>
        <input type="text" name="username" required autofocus class="w-full px-4 py-3 rounded-md border border-earth-200 focus:border-forest-500 focus:ring-2 focus:ring-forest-500/20 outline-none transition">
      </div>
      <div class="mb-6">
        <label class="block text-sm font-semibold text-forest-900 mb-1.5">Mật khẩu</label>
        <input type="password" name="password" required class="w-full px-4 py-3 rounded-md border border-earth-200 focus:border-forest-500 focus:ring-2 focus:ring-forest-500/20 outline-none transition">
      </div>
      <button type="submit" class="w-full bg-forest-700 hover:bg-forest-800 text-white py-3 rounded-md font-semibold transition">Đăng nhập</button>
    </form>
    <p class="text-center text-cream-200 text-xs mt-6">© <%= new Date().getFullYear() %> Dũng Đông</p>
  </div>
</div>
</body>
</html>

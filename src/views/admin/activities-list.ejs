<%- include('_shell') %>

<div class="mb-5 flex items-center justify-between">
  <p class="text-sm text-forest-700">Tổng <%= items.length %> hình ảnh hoạt động</p>
  <a href="/admin/activities/new" class="inline-flex items-center gap-2 bg-forest-700 hover:bg-forest-800 text-white px-4 py-2.5 rounded-md font-semibold text-sm shadow transition">
    + Thêm ảnh
  </a>
</div>

<% if (!items.length) { %>
  <div class="bg-white rounded-xl border border-earth-100 p-12 text-center text-forest-600">
    Chưa có hình ảnh hoạt động nào.
  </div>
<% } else { %>
  <div class="grid sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-4">
    <% items.forEach(function(it) { %>
      <div class="bg-white rounded-xl border border-earth-100 overflow-hidden">
        <div class="aspect-[4/3] bg-forest-50">
          <img src="<%= it.image_url %>" alt="<%= it.title %>" class="w-full h-full object-cover">
        </div>
        <div class="p-4">
          <h3 class="font-semibold text-forest-900 line-clamp-1"><%= it.title %></h3>
          <% if (it.location) { %><div class="text-xs text-earth-700 mt-1"><%= it.location %></div><% } %>
          <% if (it.description) { %><p class="text-xs text-forest-700 mt-2 line-clamp-2"><%= it.description %></p><% } %>
          <form method="POST" action="/admin/activities/<%= it.id %>/delete" class="mt-3" onsubmit="return confirm('Xóa ảnh này?')">
            <button class="text-xs text-red-700 hover:underline font-semibold">Xóa</button>
          </form>
        </div>
      </div>
    <% }); %>
  </div>
<% } %>

<%- include('_foot') %>

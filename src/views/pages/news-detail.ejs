<%- include('../partials/head') %>

<section class="bg-gradient-to-br from-forest-800 to-forest-950 text-cream-50 py-10 md:py-14 relative overflow-hidden">
  <div class="absolute inset-0 dot-pattern opacity-15"></div>
  <div class="relative max-w-4xl mx-auto px-4">
    <nav class="text-xs sm:text-sm text-cream-200 mb-4 flex items-center gap-2 flex-wrap">
      <a href="/" class="hover:text-earth-300">Trang chủ</a>
      <span>›</span>
      <a href="/tin-tuc" class="hover:text-earth-300">Tin tức</a>
      <span>›</span>
      <span class="text-earth-300 line-clamp-1"><%= post.title %></span>
    </nav>
    <div class="text-xs text-earth-300 mb-3"><%= new Date(post.created_at).toLocaleDateString('vi-VN', { year: 'numeric', month: 'long', day: 'numeric' }) %></div>
    <h1 class="font-display font-bold text-3xl sm:text-4xl lg:text-5xl leading-tight"><%= post.title %></h1>
    <% if (post.excerpt) { %>
      <p class="mt-4 text-base sm:text-lg text-cream-200 leading-relaxed"><%= post.excerpt %></p>
    <% } %>
  </div>
  <div class="wood-strip mt-10"></div>
</section>

<article class="py-12 md:py-16">
  <div class="max-w-3xl mx-auto px-4">
    <% if (post.cover_url) { %>
      <div class="aspect-[16/9] rounded-xl overflow-hidden mb-8 shadow-lg">
        <img src="<%= post.cover_url %>" alt="<%= post.title %>" class="w-full h-full object-cover">
      </div>
    <% } %>

    <div class="prose prose-news max-w-none text-forest-900 leading-relaxed">
      <%- post.content %>
    </div>

    <div class="mt-10 pt-8 border-t border-earth-200 flex flex-wrap items-center justify-between gap-4">
      <a href="/tin-tuc" class="inline-flex items-center gap-2 text-forest-700 hover:text-earth-700 font-semibold">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"/></svg>
        Tất cả bài viết
      </a>
      <a href="/lien-he" class="inline-flex items-center gap-2 bg-earth-500 hover:bg-earth-600 text-white px-5 py-2.5 rounded-md font-semibold text-sm shadow transition">
        Yêu cầu báo giá
      </a>
    </div>
  </div>
</article>

<% if (related && related.length) { %>
<section class="py-12 bg-cream-100">
  <div class="max-w-5xl mx-auto px-4">
    <h2 class="font-display font-bold text-2xl text-forest-900 mb-6 text-center">Bài viết liên quan</h2>
    <div class="grid sm:grid-cols-3 gap-5">
      <% related.forEach(function(r) { %>
        <a href="/tin-tuc/<%= r.slug %>" class="bg-white rounded-xl overflow-hidden border border-earth-100 hover:shadow-lg transition group">
          <div class="aspect-[16/10] overflow-hidden bg-forest-100">
            <% if (r.cover_url) { %>
              <img src="<%= r.cover_url %>" alt="<%= r.title %>" loading="lazy" class="w-full h-full object-cover group-hover:scale-105 transition">
            <% } else { %>
              <div class="w-full h-full bg-gradient-to-br from-forest-700 to-forest-900 flex items-center justify-center text-cream-50 font-display text-xl">Dũng Đông</div>
            <% } %>
          </div>
          <div class="p-4">
            <h3 class="font-semibold text-forest-900 line-clamp-2 group-hover:text-earth-700 transition"><%= r.title %></h3>
          </div>
        </a>
      <% }); %>
    </div>
  </div>
</section>
<% } %>

<%- include('../partials/foot') %>

<%- include('../partials/head') %>

<section class="bg-cream-50 border-b border-cream-200 py-10 md:py-14 relative overflow-hidden">
  <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_top_right,rgba(212,146,41,0.06),transparent_60%)]"></div>
  <div class="relative max-w-4xl mx-auto px-4">
    <nav class="text-xs sm:text-sm text-forest-600 mb-5 flex items-center gap-2 flex-wrap">
      <a href="/" class="hover:text-earth-700">Trang chủ</a>
      <span class="text-cream-500">›</span>
      <a href="/tin-tuc" class="hover:text-earth-700">Tin tức</a>
      <span class="text-cream-500">›</span>
      <span class="text-earth-700 font-medium line-clamp-1"><%= post.title %></span>
    </nav>
    <div class="text-xs text-earth-700 font-semibold uppercase tracking-[0.2em] mb-4"><%= new Date(post.created_at).toLocaleDateString('vi-VN', { year: 'numeric', month: 'long', day: 'numeric' }) %></div>
    <h1 class="font-display font-bold text-3xl sm:text-4xl lg:text-5xl tracking-tight text-forest-950 leading-[1.15]"><%= post.title %></h1>
    <% if (post.excerpt) { %>
      <p class="mt-5 text-base sm:text-lg text-forest-700 leading-relaxed"><%= post.excerpt %></p>
    <% } %>
  </div>
</section>

<article class="py-12 md:py-16">
  <div class="max-w-3xl mx-auto px-4">
    <% if (post.cover_url) { %>
      <div class="aspect-[16/9] rounded-2xl overflow-hidden mb-10 shadow-soft">
        <img src="<%= post.cover_url %>" alt="<%= post.title %>" class="w-full h-full object-cover">
      </div>
    <% } %>

    <div class="prose prose-news max-w-none text-forest-900 leading-relaxed">
      <%- post.content %>
    </div>

    <div class="mt-12 pt-8 border-t border-cream-200 flex flex-wrap items-center justify-between gap-4">
      <a href="/tin-tuc" class="inline-flex items-center gap-2 text-forest-700 hover:text-earth-700 font-semibold">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M10 19l-7-7m0 0l7-7m-7 7h18"/></svg>
        Tất cả bài viết
      </a>
      <a href="/lien-he" class="inline-flex items-center gap-2 bg-forest-900 hover:bg-forest-950 text-white px-5 py-2.5 rounded-xl font-semibold text-sm shadow-soft transition">
        Yêu cầu báo giá
      </a>
    </div>
  </div>
</article>

<% if (related && related.length) { %>
<section class="py-16 bg-cream-50">
  <div class="max-w-5xl mx-auto px-4">
    <div class="text-center mb-10">
      <div class="text-earth-700 font-semibold uppercase tracking-[0.2em] text-xs mb-3">Liên quan</div>
      <h2 class="font-display font-bold text-2xl sm:text-3xl text-forest-950 tracking-tight">Bài viết khác</h2>
    </div>
    <div class="grid sm:grid-cols-3 gap-5">
      <% related.forEach(function(r) { %>
        <a href="/tin-tuc/<%= r.slug %>" class="bg-white rounded-2xl overflow-hidden border border-cream-200 hover:shadow-lifted hover:border-earth-200 transition group">
          <div class="aspect-[16/10] overflow-hidden bg-cream-100">
            <% if (r.cover_url) { %>
              <img src="<%= r.cover_url %>" alt="<%= r.title %>" loading="lazy" class="w-full h-full object-cover group-hover:scale-105 transition">
            <% } else { %>
              <div class="w-full h-full bg-gradient-to-br from-forest-800 to-forest-950 flex items-center justify-center text-white font-display text-xl">Dũng Đông</div>
            <% } %>
          </div>
          <div class="p-5">
            <h3 class="font-display font-semibold text-forest-950 line-clamp-2 group-hover:text-earth-700 transition tracking-tight"><%= r.title %></h3>
          </div>
        </a>
      <% }); %>
    </div>
  </div>
</section>
<% } %>

<%- include('../partials/foot') %>

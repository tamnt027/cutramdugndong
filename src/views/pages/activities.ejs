<%- include('../partials/head') %>
<%- include('../partials/page-hero', { pageTitle: 'Hoạt động công trình', pageSubtitle: 'Hình ảnh các công trình thực tế chúng tôi đã cung cấp cừ' }) %>

<section class="py-12 md:py-16">
  <div class="max-w-7xl mx-auto px-4">
    <% if (!activities.length) { %>
      <p class="text-center text-forest-700 py-16">Chưa có hình ảnh hoạt động nào được cập nhật.</p>
    <% } else { %>
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4 sm:gap-5">
        <% activities.forEach(function(a) { %>
          <div class="group">
            <div class="relative aspect-[4/3] rounded-xl overflow-hidden cursor-pointer shadow-md hover:shadow-xl transition" data-lightbox="<%= a.image_url %>">
              <img src="<%= a.image_url %>" alt="<%= a.title %>" loading="lazy" class="w-full h-full object-cover group-hover:scale-110 transition duration-500">
              <div class="absolute inset-0 bg-gradient-to-t from-forest-950/80 via-transparent to-transparent opacity-0 group-hover:opacity-100 transition"></div>
              <div class="absolute top-3 right-3 w-9 h-9 rounded-full bg-white/90 flex items-center justify-center opacity-0 group-hover:opacity-100 transition">
                <svg class="w-4 h-4 text-forest-900" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/></svg>
              </div>
            </div>
            <div class="mt-3 px-1">
              <h3 class="font-semibold text-forest-900 line-clamp-1"><%= a.title %></h3>
              <% if (a.description) { %><p class="text-sm text-forest-700 line-clamp-2 mt-1"><%= a.description %></p><% } %>
              <% if (a.location) { %>
                <div class="text-xs text-earth-700 mt-1.5 flex items-center gap-1">
                  <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M5.05 4.05a7 7 0 119.9 9.9L10 18.9l-4.95-4.95a7 7 0 010-9.9zM10 11a2 2 0 100-4 2 2 0 000 4z" clip-rule="evenodd"/></svg>
                  <%= a.location %>
                </div>
              <% } %>
            </div>
          </div>
        <% }); %>
      </div>
    <% } %>
  </div>
</section>

<%- include('../partials/foot') %>

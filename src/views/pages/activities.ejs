<%- include('../partials/head') %>
<%- include('../partials/page-hero', { pageTitle: 'Hoạt động công trình', pageSubtitle: 'Hình ảnh các công trình thực tế chúng tôi đã cung cấp cừ' }) %>

<section class="py-16 md:py-20">
  <div class="max-w-7xl mx-auto px-4">
    <% if (!activities.length) { %>
      <p class="text-center text-forest-700 py-16">Chưa có hình ảnh hoạt động nào được cập nhật.</p>
    <% } else { %>
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4 md:gap-5">
        <% activities.forEach(function(a) { %>
          <div class="group">
            <div class="relative aspect-[4/3] rounded-2xl overflow-hidden cursor-pointer shadow-soft hover:shadow-lifted transition" data-lightbox="<%= a.image_url %>">
              <img src="<%= a.image_url %>" alt="<%= a.title %>" loading="lazy" class="w-full h-full object-cover group-hover:scale-105 transition duration-500">
              <div class="absolute inset-0 bg-gradient-to-t from-forest-950/40 to-transparent opacity-0 group-hover:opacity-100 transition"></div>
              <div class="absolute top-3 right-3 w-9 h-9 rounded-full bg-white/95 backdrop-blur flex items-center justify-center opacity-0 group-hover:opacity-100 transition">
                <svg class="w-4 h-4 text-forest-950" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/></svg>
              </div>
            </div>
            <div class="mt-3 px-1">
              <h3 class="font-semibold text-forest-950 line-clamp-1"><%= a.title %></h3>
              <% if (a.description) { %><p class="text-sm text-forest-700 line-clamp-2 mt-1"><%= a.description %></p><% } %>
              <% if (a.location) { %>
                <div class="text-xs text-earth-700 mt-2 flex items-center gap-1.5 font-medium">
                  <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
                  <%= a.location %>
                </div>
              <% } %>
            </div>
          </div>
        <% }); %>
      </div>
    <% } %>
  </div>
</section>

<%- include('../partials/foot') %>

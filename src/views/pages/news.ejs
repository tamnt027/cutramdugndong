<%- include('../partials/head') %>
<%- include('../partials/page-hero', { pageTitle: 'Tin tức', pageSubtitle: 'Kiến thức về cừ tràm, hướng dẫn chọn cừ và bảng giá cập nhật' }) %>

<section class="py-12 md:py-16">
  <div class="max-w-7xl mx-auto px-4">
    <% if (!posts.length) { %>
      <p class="text-center text-forest-700 py-16">Chưa có bài viết nào.</p>
    <% } else { %>
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
        <% posts.forEach(function(p) { %>
          <article class="bg-white rounded-xl overflow-hidden border border-earth-100 hover:shadow-lg transition group">
            <a href="/tin-tuc/<%= p.slug %>" class="block aspect-[16/10] overflow-hidden bg-forest-100">
              <% if (p.cover_url) { %>
                <img src="<%= p.cover_url %>" alt="<%= p.title %>" loading="lazy" class="w-full h-full object-cover group-hover:scale-105 transition">
              <% } else { %>
                <div class="w-full h-full bg-gradient-to-br from-forest-700 to-forest-900 flex items-center justify-center text-cream-50 font-display text-2xl">Dũng Đông</div>
              <% } %>
            </a>
            <div class="p-5">
              <div class="text-xs text-earth-600 mb-2"><%= new Date(p.created_at).toLocaleDateString('vi-VN') %></div>
              <h2 class="font-display font-bold text-lg text-forest-900 mb-2 line-clamp-2 group-hover:text-earth-700 transition">
                <a href="/tin-tuc/<%= p.slug %>"><%= p.title %></a>
              </h2>
              <p class="text-sm text-forest-700 line-clamp-3 mb-3"><%= p.excerpt %></p>
              <a href="/tin-tuc/<%= p.slug %>" class="inline-flex items-center gap-1 text-sm font-semibold text-forest-700 group-hover:text-earth-700">
                Đọc tiếp →
              </a>
            </div>
          </article>
        <% }); %>
      </div>

      <% if (totalPages > 1) { %>
        <nav class="mt-10 flex justify-center gap-2">
          <% for (let i = 1; i <= totalPages; i++) { %>
            <a href="?page=<%= i %>" class="w-10 h-10 inline-flex items-center justify-center rounded-md font-semibold text-sm <%= i === page ? 'bg-forest-700 text-cream-50' : 'bg-white text-forest-700 border border-earth-200 hover:bg-cream-100' %>"><%= i %></a>
          <% } %>
        </nav>
      <% } %>
    <% } %>
  </div>
</section>

<%- include('../partials/foot') %>

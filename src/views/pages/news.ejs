<%- include('../partials/head') %>
<%- include('../partials/page-hero', { pageTitle: 'Tin tức', pageSubtitle: 'Kiến thức về cừ tràm, hướng dẫn chọn cừ và bảng giá cập nhật' }) %>

<section class="py-16 md:py-20">
  <div class="max-w-7xl mx-auto px-4">
    <% if (!posts.length) { %>
      <p class="text-center text-forest-700 py-16">Chưa có bài viết nào.</p>
    <% } else { %>
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-5 md:gap-6">
        <% posts.forEach(function(p) { %>
          <article class="bg-white rounded-2xl overflow-hidden border border-cream-200 hover:shadow-lifted hover:border-earth-200 transition group">
            <a href="/tin-tuc/<%= p.slug %>" class="block aspect-[16/10] overflow-hidden bg-cream-100">
              <% if (p.cover_url) { %>
                <img src="<%= p.cover_url %>" alt="<%= p.title %>" loading="lazy" class="w-full h-full object-cover group-hover:scale-105 transition duration-500">
              <% } else { %>
                <div class="w-full h-full bg-gradient-to-br from-forest-800 to-forest-950 flex items-center justify-center text-white font-display text-2xl">Dũng Đông</div>
              <% } %>
            </a>
            <div class="p-5 md:p-6">
              <div class="text-xs text-earth-700 font-medium mb-2"><%= new Date(p.created_at).toLocaleDateString('vi-VN') %></div>
              <h2 class="font-display font-bold text-xl text-forest-950 mb-2 line-clamp-2 tracking-tight group-hover:text-earth-700 transition">
                <a href="/tin-tuc/<%= p.slug %>"><%= p.title %></a>
              </h2>
              <p class="text-sm text-forest-700 line-clamp-3 mb-4"><%= p.excerpt %></p>
              <a href="/tin-tuc/<%= p.slug %>" class="inline-flex items-center gap-1.5 text-sm font-semibold text-forest-900 group-hover:text-earth-700">
                Đọc tiếp
                <svg class="w-4 h-4 group-hover:translate-x-0.5 transition" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M14 5l7 7m0 0l-7 7m7-7H3"/></svg>
              </a>
            </div>
          </article>
        <% }); %>
      </div>

      <% if (totalPages > 1) { %>
        <nav class="mt-12 flex justify-center gap-2">
          <% for (let i = 1; i <= totalPages; i++) { %>
            <a href="?page=<%= i %>" class="w-10 h-10 inline-flex items-center justify-center rounded-lg font-semibold text-sm <%= i === page ? 'bg-forest-900 text-white' : 'bg-white text-forest-700 border border-cream-200 hover:bg-cream-100' %>"><%= i %></a>
          <% } %>
        </nav>
      <% } %>
    <% } %>
  </div>
</section>

<%- include('../partials/foot') %>

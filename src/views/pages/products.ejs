<%- include('../partials/head') %>
<%- include('../partials/page-hero', { pageTitle: 'Sản phẩm', pageSubtitle: '4 dòng sản phẩm chính - đầy đủ kích thước cho mọi loại công trình' }) %>

<section class="py-16 md:py-20">
  <div class="max-w-7xl mx-auto px-4">
    <div class="space-y-8 lg:space-y-10">
      <% products.forEach(function(p, idx) { %>
        <article class="bg-white rounded-3xl border border-cream-200 overflow-hidden shadow-soft hover:shadow-lifted transition">
          <div class="grid md:grid-cols-2 gap-0">
            <div class="relative aspect-[4/3] md:aspect-auto md:min-h-[360px] order-1 <%= idx % 2 ? 'md:order-2' : '' %>">
              <img src="<%= p.cover %>" alt="<%= p.name %>" loading="lazy" class="absolute inset-0 w-full h-full object-cover">
              <div class="absolute top-5 left-5 px-3 py-1 bg-white/95 backdrop-blur text-forest-950 text-xs font-bold uppercase tracking-[0.18em] rounded-full"><%= idx + 1 %> / 4</div>
            </div>
            <div class="p-6 sm:p-10 flex flex-col justify-center order-2 <%= idx % 2 ? 'md:order-1' : '' %>">
              <div class="text-earth-700 font-semibold uppercase tracking-[0.2em] text-xs mb-3"><%= p.tagline %></div>
              <h2 class="font-display font-bold text-3xl sm:text-4xl text-forest-950 tracking-tight mb-4"><%= p.name %></h2>
              <p class="text-forest-700 mb-6 leading-relaxed"><%= p.short %></p>

              <div class="grid grid-cols-2 gap-2.5 mb-7">
                <% p.specs.slice(0, 4).forEach(function(s) { %>
                  <div class="bg-cream-50 rounded-xl px-4 py-3 border border-cream-100">
                    <div class="text-[10px] text-forest-600 uppercase tracking-wider font-medium mb-0.5"><%= s.label %></div>
                    <div class="font-semibold text-forest-950 text-sm"><%= s.value %></div>
                  </div>
                <% }); %>
              </div>

              <div class="flex flex-wrap gap-3">
                <a href="/san-pham/<%= p.slug %>" class="inline-flex items-center gap-2 bg-forest-900 hover:bg-forest-950 text-white px-5 py-2.5 rounded-xl font-semibold text-sm transition">
                  Xem chi tiết
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M14 5l7 7m0 0l-7 7m7-7H3"/></svg>
                </a>
                <a href="/lien-he?product=<%= p.slug %>" class="inline-flex items-center gap-2 border border-earth-300 text-earth-700 hover:bg-earth-500 hover:text-white hover:border-earth-500 px-5 py-2.5 rounded-xl font-semibold text-sm transition">
                  Yêu cầu báo giá
                </a>
              </div>
            </div>
          </div>
        </article>
      <% }); %>
    </div>
  </div>
</section>

<%- include('../partials/foot') %>

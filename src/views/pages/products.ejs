<%- include('../partials/head') %>
<%- include('../partials/page-hero', { pageTitle: 'Sản phẩm', pageSubtitle: '4 dòng sản phẩm chính - đầy đủ kích thước cho mọi loại công trình' }) %>

<section class="py-12 md:py-16">
  <div class="max-w-7xl mx-auto px-4">
    <div class="space-y-10">
      <% products.forEach(function(p, idx) { %>
        <article class="bg-white rounded-2xl border border-earth-100 overflow-hidden shadow-sm hover:shadow-lg transition">
          <div class="grid md:grid-cols-2 gap-0">
            <div class="relative aspect-[4/3] md:aspect-auto md:min-h-[320px] order-1 <%= idx % 2 ? 'md:order-2' : '' %>">
              <img src="<%= p.cover %>" alt="<%= p.name %>" loading="lazy" class="absolute inset-0 w-full h-full object-cover">
              <div class="absolute top-4 left-4 px-3 py-1 bg-earth-500 text-white text-xs font-bold uppercase tracking-wider rounded-full"><%= idx + 1 %>/4</div>
            </div>
            <div class="p-6 sm:p-8 flex flex-col justify-center order-2 <%= idx % 2 ? 'md:order-1' : '' %>">
              <div class="font-display font-semibold uppercase tracking-widest text-xs text-earth-600 mb-2"><%= p.tagline %></div>
              <h2 class="font-display font-bold text-2xl sm:text-3xl text-forest-900 mb-3"><%= p.name %></h2>
              <p class="text-forest-700 mb-5 leading-relaxed"><%= p.short %></p>

              <div class="grid grid-cols-2 gap-2 mb-6 text-sm">
                <% p.specs.slice(0, 4).forEach(function(s) { %>
                  <div class="bg-cream-100 rounded-lg px-3 py-2">
                    <div class="text-xs text-forest-600"><%= s.label %></div>
                    <div class="font-semibold text-forest-900"><%= s.value %></div>
                  </div>
                <% }); %>
              </div>

              <div class="flex flex-wrap gap-3">
                <a href="/san-pham/<%= p.slug %>" class="inline-flex items-center gap-2 bg-forest-700 hover:bg-forest-800 text-white px-5 py-2.5 rounded-md font-semibold text-sm transition">
                  Xem chi tiết
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"/></svg>
                </a>
                <a href="/lien-he?product=<%= p.slug %>" class="inline-flex items-center gap-2 border-2 border-earth-500 text-earth-700 hover:bg-earth-500 hover:text-white px-5 py-2.5 rounded-md font-semibold text-sm transition">
                  Yêu cầu báo giá
                </a>
              </div>
            </div>
          </div>
        </article>
      <% }); %>
    </div>
  </div>
</section>

<%- include('../partials/foot') %>

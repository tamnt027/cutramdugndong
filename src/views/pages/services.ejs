<%- include('../partials/head') %>
<%- include('../partials/page-hero', { pageTitle: 'Dịch vụ', pageSubtitle: 'Trọn gói từ tư vấn, cung cấp đến vận chuyển và hỗ trợ thi công' }) %>

<section class="py-12 md:py-16">
  <div class="max-w-6xl mx-auto px-4">
    <div class="grid md:grid-cols-2 gap-6">
      <% [
        { t: 'Tư vấn loại cừ và mật độ đóng', d: 'Khảo sát địa chất, tải trọng công trình để đề xuất loại cừ (tràm, bạch đàn, dừa) và mật độ đóng phù hợp (16/25/36 cây/m²). Tư vấn miễn phí.', icon: '📐' },
        { t: 'Cung cấp số lượng lớn', d: 'Đáp ứng đơn hàng từ vài chục đến hàng nghìn cây. Có sẵn kho hàng, không phụ thuộc mùa khai thác.', icon: '🏗️' },
        { t: 'Vận chuyển tận công trình', d: 'Xe tải chuyên dụng các loại tải trọng. Miễn phí vận chuyển nội thành TP.HCM cho đơn từ 500 cây.', icon: '🚛' },
        { t: 'Bốc dỡ tại chân công trình', d: 'Hỗ trợ bốc xếp xuống xe tại địa điểm khách yêu cầu. Có cẩu hỗ trợ với cừ dừa lớn.', icon: '🏋️' },
        { t: 'Liên kết đội thi công đóng cừ', d: 'Giới thiệu đội thợ uy tín có kinh nghiệm đóng cừ thủ công và bằng máy. Giá thi công thỏa thuận trực tiếp.', icon: '👷' },
        { t: 'Bảo hành chất lượng', d: 'Cam kết hoàn tiền hoặc đổi hàng nếu cừ không đúng chất lượng đã thỏa thuận. Khách kiểm hàng tại công trình trước khi nhận.', icon: '🛡️' },
      ].forEach(function(s) { %>
        <div class="bg-white rounded-xl p-6 border border-earth-100 hover:border-earth-300 hover:shadow-lg transition flex gap-4">
          <div class="text-4xl flex-shrink-0"><%= s.icon %></div>
          <div>
            <h3 class="font-display font-bold text-lg text-forest-900 mb-2"><%= s.t %></h3>
            <p class="text-sm text-forest-700 leading-relaxed"><%= s.d %></p>
          </div>
        </div>
      <% }); %>
    </div>
  </div>
</section>

<section class="py-12 md:py-16 bg-cream-100">
  <div class="max-w-5xl mx-auto px-4">
    <h2 class="font-display font-bold text-3xl text-forest-900 mb-3 text-center">Quy trình đặt hàng</h2>
    <p class="text-center text-forest-700 mb-10">Chỉ 4 bước đơn giản, bạn nhận hàng ngay trong ngày.</p>
    <div class="space-y-4">
      <% [
        { n: '1', t: 'Liên hệ hotline hoặc gửi form', d: 'Cho biết loại cừ, kích thước, số lượng và địa điểm giao hàng.' },
        { n: '2', t: 'Nhận báo giá chi tiết', d: 'Báo giá chính xác trong vòng 30 phút. Có thể gửi ảnh hàng mẫu nếu khách yêu cầu.' },
        { n: '3', t: 'Đặt cọc và lên lịch giao', d: 'Đặt cọc 30% (đơn lớn) hoặc thanh toán khi nhận hàng (đơn nhỏ). Lên lịch giao theo yêu cầu.' },
        { n: '4', t: 'Giao hàng - Nghiệm thu - Thanh toán', d: 'Khách kiểm hàng tại công trình. Nếu đạt yêu cầu, thanh toán phần còn lại.' },
      ].forEach(function(s) { %>
        <div class="bg-white rounded-xl p-5 border border-earth-100 flex items-start gap-5">
          <div class="w-12 h-12 rounded-full bg-forest-700 text-cream-50 flex items-center justify-center font-display font-bold text-xl flex-shrink-0"><%= s.n %></div>
          <div>
            <h3 class="font-display font-bold text-lg text-forest-900 mb-1"><%= s.t %></h3>
            <p class="text-sm text-forest-700"><%= s.d %></p>
          </div>
        </div>
      <% }); %>
    </div>
    <div class="mt-10 text-center">
      <a href="/lien-he" class="inline-flex items-center gap-2 bg-earth-500 hover:bg-earth-600 text-white px-6 py-3.5 rounded-md font-bold shadow transition">
        Bắt đầu đặt hàng
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"/></svg>
      </a>
    </div>
  </div>
</section>

<%- include('../partials/foot') %>

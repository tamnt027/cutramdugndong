<%- include('../partials/head') %>
<%- include('../partials/page-hero', { pageTitle: 'Dịch vụ', pageSubtitle: 'Trọn gói từ tư vấn, cung cấp đến vận chuyển và hỗ trợ thi công' }) %>

<section class="py-16 md:py-20">
  <div class="max-w-6xl mx-auto px-4">
    <div class="grid md:grid-cols-2 gap-5">
      <% [
        { t: 'Tư vấn loại cừ và mật độ đóng', d: 'Khảo sát địa chất, tải trọng công trình để đề xuất loại cừ (tràm, bạch đàn, dừa) và mật độ đóng phù hợp (16/25/36 cây/m²). Tư vấn miễn phí.', svg: 'M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4' },
        { t: 'Cung cấp số lượng lớn', d: 'Đáp ứng đơn hàng từ vài chục đến hàng nghìn cây. Có sẵn kho hàng, không phụ thuộc mùa khai thác.', svg: 'M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4' },
        { t: 'Vận chuyển tận công trình', d: 'Xe tải chuyên dụng các loại tải trọng. Miễn phí vận chuyển nội thành TP.HCM cho đơn từ 500 cây.', svg: 'M9 17a2 2 0 11-4 0 2 2 0 014 0zM19 17a2 2 0 11-4 0 2 2 0 014 0z M13 16V6a1 1 0 00-1-1H4a1 1 0 00-1 1v10a1 1 0 001 1h1m8-1a1 1 0 01-1 1H9m4-1V8a1 1 0 011-1h2.586a1 1 0 01.707.293l3.414 3.414a1 1 0 01.293.707V16a1 1 0 01-1 1h-1' },
        { t: 'Bốc dỡ tại chân công trình', d: 'Hỗ trợ bốc xếp xuống xe tại địa điểm khách yêu cầu. Có cẩu hỗ trợ với cừ dừa lớn.', svg: 'M7 16a4 4 0 01-.88-7.903A5 5 0 1115.9 6L16 6a5 5 0 011 9.9M15 13l-3-3m0 0l-3 3m3-3v12' },
        { t: 'Liên kết đội thi công', d: 'Giới thiệu đội thợ uy tín có kinh nghiệm đóng cừ thủ công và bằng máy. Giá thi công thỏa thuận trực tiếp.', svg: 'M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z' },
        { t: 'Bảo hành chất lượng', d: 'Cam kết hoàn tiền hoặc đổi hàng nếu cừ không đúng chất lượng đã thỏa thuận. Khách kiểm hàng tại công trình trước khi nhận.', svg: 'M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z' },
      ].forEach(function(s) { %>
        <div class="bg-white rounded-2xl p-6 border border-cream-200 hover:border-earth-200 hover:shadow-soft transition flex gap-5">
          <div class="w-12 h-12 rounded-xl bg-forest-900 text-white flex items-center justify-center flex-shrink-0">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="<%= s.svg %>"/></svg>
          </div>
          <div>
            <h3 class="font-display font-bold text-lg text-forest-950 mb-2 tracking-tight"><%= s.t %></h3>
            <p class="text-sm text-forest-700 leading-relaxed"><%= s.d %></p>
          </div>
        </div>
      <% }); %>
    </div>
  </div>
</section>

<section class="py-16 md:py-20 bg-cream-50">
  <div class="max-w-5xl mx-auto px-4">
    <div class="text-center mb-12">
      <div class="text-earth-700 font-semibold uppercase tracking-[0.2em] text-xs mb-3">Quy trình</div>
      <h2 class="font-display font-bold text-3xl sm:text-4xl text-forest-950 tracking-tight mb-3">Quy trình đặt hàng</h2>
      <p class="text-forest-700">Chỉ 4 bước đơn giản, bạn nhận hàng ngay trong ngày.</p>
    </div>
    <div class="space-y-4">
      <% [
        { n: '1', t: 'Liên hệ hotline hoặc gửi form', d: 'Cho biết loại cừ, kích thước, số lượng và địa điểm giao hàng.' },
        { n: '2', t: 'Nhận báo giá chi tiết', d: 'Báo giá chính xác trong vòng 30 phút. Có thể gửi ảnh hàng mẫu nếu khách yêu cầu.' },
        { n: '3', t: 'Đặt cọc và lên lịch giao', d: 'Đặt cọc 30% (đơn lớn) hoặc thanh toán khi nhận hàng (đơn nhỏ). Lên lịch giao theo yêu cầu.' },
        { n: '4', t: 'Giao hàng - Nghiệm thu - Thanh toán', d: 'Khách kiểm hàng tại công trình. Nếu đạt yêu cầu, thanh toán phần còn lại.' },
      ].forEach(function(s) { %>
        <div class="bg-white rounded-2xl p-6 border border-cream-200 flex items-start gap-5">
          <div class="w-12 h-12 rounded-xl bg-earth-500 text-white flex items-center justify-center font-display font-bold text-xl flex-shrink-0"><%= s.n %></div>
          <div>
            <h3 class="font-display font-bold text-lg text-forest-950 mb-1 tracking-tight"><%= s.t %></h3>
            <p class="text-sm text-forest-700"><%= s.d %></p>
          </div>
        </div>
      <% }); %>
    </div>
    <div class="mt-12 text-center">
      <a href="/lien-he" class="inline-flex items-center gap-2 bg-forest-900 hover:bg-forest-950 text-white px-7 py-3.5 rounded-xl font-semibold shadow-soft transition">
        Bắt đầu đặt hàng
        <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M14 5l7 7m0 0l-7 7m7-7H3"/></svg>
      </a>
    </div>
  </div>
</section>

<%- include('../partials/foot') %>

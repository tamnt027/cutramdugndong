<%- include('../partials/head') %>

<section class="bg-gradient-to-br from-forest-800 to-forest-950 text-cream-50 py-10 md:py-16 relative overflow-hidden">
  <div class="absolute inset-0 dot-pattern opacity-15"></div>
  <div class="relative max-w-7xl mx-auto px-4">
    <nav class="text-xs sm:text-sm text-cream-200 mb-4 flex items-center gap-2 flex-wrap">
      <a href="/" class="hover:text-earth-300">Trang chủ</a>
      <span>›</span>
      <a href="/san-pham" class="hover:text-earth-300">Sản phẩm</a>
      <span>›</span>
      <span class="text-earth-300"><%= product.name %></span>
    </nav>
    <div class="grid lg:grid-cols-2 gap-8 lg:gap-12 items-center">
      <div>
        <div class="font-display font-semibold uppercase tracking-widest text-sm text-earth-400 mb-2"><%= product.tagline %></div>
        <h1 class="font-display font-bold text-3xl sm:text-4xl lg:text-5xl mb-4"><%= product.name %></h1>
        <p class="text-base sm:text-lg text-cream-200 leading-relaxed mb-6"><%= product.short %></p>
        <div class="flex flex-col sm:flex-row gap-3">
          <a href="tel:<%= company.hotline %>" class="inline-flex items-center justify-center gap-2 bg-earth-500 hover:bg-earth-600 text-white px-6 py-3.5 rounded-md font-bold shadow-lg transition">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 20 20"><path d="M2 3a1 1 0 011-1h2.153a1 1 0 01.986.836l.74 4.435a1 1 0 01-.54 1.06l-1.548.773a11.037 11.037 0 006.105 6.105l.774-1.548a1 1 0 011.059-.54l4.435.74a1 1 0 01.836.986V17a1 1 0 01-1 1h-2C7.82 18 2 12.18 2 5V3z"/></svg>
            Gọi <%= company.hotlineDisplay %>
          </a>
          <a href="/lien-he?product=<%= product.slug %>" class="inline-flex items-center justify-center gap-2 bg-cream-50/10 hover:bg-cream-50/20 border border-cream-50/30 text-cream-50 px-6 py-3.5 rounded-md font-semibold transition backdrop-blur">
            Yêu cầu báo giá
          </a>
        </div>
      </div>
      <div class="aspect-[4/3] rounded-2xl overflow-hidden shadow-2xl border-4 border-earth-500/30">
        <img src="<%= product.cover %>" alt="<%= product.name %>" class="w-full h-full object-cover">
      </div>
    </div>
  </div>
  <div class="wood-strip mt-10"></div>
</section>

<!-- Thong so + Ung dung + Uu diem -->
<section class="py-12 md:py-16">
  <div class="max-w-7xl mx-auto px-4 grid lg:grid-cols-3 gap-6">
    <div class="bg-white rounded-2xl p-6 border border-earth-100">
      <div class="w-12 h-12 rounded-lg bg-forest-100 text-forest-700 flex items-center justify-center mb-4">
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/></svg>
      </div>
      <h3 class="font-display font-bold text-xl text-forest-900 mb-4">Thông số kỹ thuật</h3>
      <dl class="space-y-2 text-sm">
        <% product.specs.forEach(function(s) { %>
          <div class="flex justify-between border-b border-earth-100 pb-2">
            <dt class="text-forest-700"><%= s.label %></dt>
            <dd class="font-semibold text-forest-900 text-right"><%= s.value %></dd>
          </div>
        <% }); %>
      </dl>
    </div>

    <div class="bg-white rounded-2xl p-6 border border-earth-100">
      <div class="w-12 h-12 rounded-lg bg-earth-100 text-earth-700 flex items-center justify-center mb-4">
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"/></svg>
      </div>
      <h3 class="font-display font-bold text-xl text-forest-900 mb-4">Ứng dụng</h3>
      <ul class="space-y-2 text-sm text-forest-800">
        <% product.applications.forEach(function(a) { %>
          <li class="flex items-start gap-2">
            <svg class="w-4 h-4 text-forest-600 mt-0.5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/></svg>
            <span><%= a %></span>
          </li>
        <% }); %>
      </ul>
    </div>

    <div class="bg-white rounded-2xl p-6 border border-earth-100">
      <div class="w-12 h-12 rounded-lg bg-forest-100 text-forest-700 flex items-center justify-center mb-4">
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z"/></svg>
      </div>
      <h3 class="font-display font-bold text-xl text-forest-900 mb-4">Ưu điểm</h3>
      <ul class="space-y-2 text-sm text-forest-800">
        <% product.advantages.forEach(function(a) { %>
          <li class="flex items-start gap-2">
            <span class="text-earth-500 font-bold mt-0.5">★</span>
            <span><%= a %></span>
          </li>
        <% }); %>
      </ul>
    </div>
  </div>
</section>

<!-- Bang gia -->
<section class="py-12 md:py-16 bg-cream-100">
  <div class="max-w-5xl mx-auto px-4">
    <div class="text-center mb-8">
      <div class="font-display font-semibold uppercase tracking-widest text-sm text-earth-600 mb-2">Bảng giá tham khảo</div>
      <h2 class="font-display font-bold text-3xl text-forest-900">Giá <%= product.name.toLowerCase() %> mới nhất</h2>
      <p class="text-sm text-forest-600 mt-2">Giá có thể thay đổi theo số lượng và vị trí giao. Vui lòng gọi hotline để có giá chính xác.</p>
    </div>

    <div class="bg-white rounded-2xl overflow-hidden border border-earth-100 shadow-sm">
      <div class="overflow-x-auto">
        <table class="w-full text-sm sm:text-base">
          <thead class="bg-forest-700 text-cream-50">
            <tr>
              <th class="px-4 sm:px-6 py-4 text-left font-semibold">Loại</th>
              <th class="px-4 sm:px-6 py-4 text-left font-semibold">Quy cách</th>
              <th class="px-4 sm:px-6 py-4 text-left font-semibold">Đơn vị</th>
              <th class="px-4 sm:px-6 py-4 text-right font-semibold">Giá</th>
            </tr>
          </thead>
          <tbody>
            <% product.pricing.forEach(function(row, i) { %>
              <tr class="<%= i % 2 ? 'bg-cream-50' : '' %> border-b border-earth-100 last:border-0">
                <td class="px-4 sm:px-6 py-4 font-semibold text-forest-900"><%= row.type %></td>
                <td class="px-4 sm:px-6 py-4 text-forest-700"><%= row.size %></td>
                <td class="px-4 sm:px-6 py-4 text-forest-700"><%= row.unit %></td>
                <td class="px-4 sm:px-6 py-4 text-right">
                  <a href="tel:<%= company.hotline %>" class="inline-flex items-center gap-1.5 text-earth-700 font-bold hover:text-earth-800">
                    <%= row.note %>
                    <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20"><path d="M2 3a1 1 0 011-1h2.153a1 1 0 01.986.836l.74 4.435a1 1 0 01-.54 1.06l-1.548.773a11.037 11.037 0 006.105 6.105l.774-1.548a1 1 0 011.059-.54l4.435.74a1 1 0 01.836.986V17a1 1 0 01-1 1h-2C7.82 18 2 12.18 2 5V3z"/></svg>
                  </a>
                </td>
              </tr>
            <% }); %>
          </tbody>
        </table>
      </div>
    </div>

    <div class="mt-6 bg-earth-50 border border-earth-200 rounded-xl p-5 text-sm text-forest-800">
      <strong class="text-forest-900">Lưu ý:</strong> Bảng giá trên mang tính tham khảo. Giá thực tế phụ thuộc vào số lượng đặt, kích thước cụ thể, vị trí giao hàng và thời điểm đặt hàng. Liên hệ hotline <a href="tel:<%= company.hotline %>" class="text-earth-700 font-semibold underline"><%= company.hotlineDisplay %></a> để nhận báo giá chính xác trong vòng 30 phút.
    </div>
  </div>
</section>

<!-- Gallery -->
<% if (product.gallery && product.gallery.length) { %>
<section class="py-12 md:py-16">
  <div class="max-w-7xl mx-auto px-4">
    <h2 class="font-display font-bold text-2xl sm:text-3xl text-forest-900 mb-6 text-center">Hình ảnh thực tế</h2>
    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4">
      <% product.gallery.forEach(function(img) { %>
        <div class="aspect-[4/3] rounded-xl overflow-hidden cursor-pointer shadow hover:shadow-xl transition" data-lightbox="<%= img %>">
          <img src="<%= img %>" alt="<%= product.name %>" loading="lazy" class="w-full h-full object-cover hover:scale-110 transition duration-500">
        </div>
      <% }); %>
    </div>
  </div>
</section>
<% } %>

<!-- CTA -->
<section class="py-14 md:py-16 bg-gradient-to-br from-earth-700 to-earth-900 text-white">
  <div class="max-w-4xl mx-auto px-4 text-center">
    <h2 class="font-display font-bold text-2xl sm:text-3xl mb-4">Cần báo giá chi tiết cho <%= product.name.toLowerCase() %>?</h2>
    <p class="text-cream-100 mb-6 text-sm sm:text-base">Gửi thông tin công trình, chúng tôi báo giá trong vòng 30 phút.</p>
    <div class="flex flex-col sm:flex-row gap-3 justify-center">
      <a href="tel:<%= company.hotline %>" class="inline-flex items-center justify-center gap-2 bg-white text-earth-800 hover:bg-cream-100 px-6 py-3.5 rounded-md font-bold shadow transition">
        Gọi <%= company.hotlineDisplay %>
      </a>
      <a href="/lien-he?product=<%= product.slug %>" class="inline-flex items-center justify-center gap-2 bg-forest-900 hover:bg-forest-950 text-white px-6 py-3.5 rounded-md font-semibold shadow transition">
        Gửi yêu cầu báo giá
      </a>
    </div>
  </div>
</section>

<%- include('../partials/foot') %>

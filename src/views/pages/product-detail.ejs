<%- include('../partials/head') %>

<section class="bg-cream-50 border-b border-cream-200 py-10 md:py-16 relative overflow-hidden">
  <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_top_right,rgba(212,146,41,0.08),transparent_60%)]"></div>
  <div class="relative max-w-7xl mx-auto px-4">
    <nav class="text-xs sm:text-sm text-forest-600 mb-6 flex items-center gap-2 flex-wrap">
      <a href="/" class="hover:text-earth-700">Trang chủ</a>
      <span class="text-cream-500">›</span>
      <a href="/san-pham" class="hover:text-earth-700">Sản phẩm</a>
      <span class="text-cream-500">›</span>
      <span class="text-earth-700 font-medium"><%= product.name %></span>
    </nav>
    <div class="grid lg:grid-cols-2 gap-8 lg:gap-14 items-center">
      <div>
        <div class="text-earth-700 font-semibold uppercase tracking-[0.2em] text-xs mb-3"><%= product.tagline %></div>
        <h1 class="font-display font-bold text-4xl sm:text-5xl lg:text-6xl tracking-tight text-forest-950 mb-5 leading-[1.1]"><%= product.name %></h1>
        <p class="text-base sm:text-lg text-forest-700 leading-relaxed mb-8"><%= product.short %></p>
        <div class="flex flex-col sm:flex-row gap-3">
          <a href="tel:<%= company.hotline %>" class="inline-flex items-center justify-center gap-2 bg-forest-900 hover:bg-forest-950 text-white px-6 py-3.5 rounded-xl font-semibold shadow-soft transition">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 20 20"><path d="M2 3a1 1 0 011-1h2.153a1 1 0 01.986.836l.74 4.435a1 1 0 01-.54 1.06l-1.548.773a11.037 11.037 0 006.105 6.105l.774-1.548a1 1 0 011.059-.54l4.435.74a1 1 0 01.836.986V17a1 1 0 01-1 1h-2C7.82 18 2 12.18 2 5V3z"/></svg>
            Gọi <%= company.hotlineDisplay %>
          </a>
          <a href="/lien-he?product=<%= product.slug %>" class="inline-flex items-center justify-center gap-2 bg-white hover:bg-cream-100 border border-forest-200 text-forest-900 px-6 py-3.5 rounded-xl font-semibold shadow-soft transition">
            Yêu cầu báo giá
          </a>
        </div>
      </div>
      <div class="aspect-[4/3] rounded-3xl overflow-hidden shadow-lifted">
        <img src="<%= product.cover %>" alt="<%= product.name %>" class="w-full h-full object-cover">
      </div>
    </div>
  </div>
</section>

<!-- Thong so + Ung dung + Uu diem -->
<section class="py-16 md:py-20">
  <div class="max-w-7xl mx-auto px-4 grid lg:grid-cols-3 gap-5 md:gap-6">
    <div class="bg-white rounded-2xl p-7 border border-cream-200">
      <div class="w-12 h-12 rounded-xl bg-forest-900 text-white flex items-center justify-center mb-5">
        <svg class="w-6 h-6" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/></svg>
      </div>
      <h3 class="font-display font-bold text-xl text-forest-950 mb-5 tracking-tight">Thông số kỹ thuật</h3>
      <dl class="space-y-3 text-sm">
        <% product.specs.forEach(function(s) { %>
          <div class="flex justify-between border-b border-cream-200 pb-3">
            <dt class="text-forest-600"><%= s.label %></dt>
            <dd class="font-semibold text-forest-950 text-right"><%= s.value %></dd>
          </div>
        <% }); %>
      </dl>
    </div>

    <div class="bg-white rounded-2xl p-7 border border-cream-200">
      <div class="w-12 h-12 rounded-xl bg-earth-500 text-white flex items-center justify-center mb-5">
        <svg class="w-6 h-6" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"/></svg>
      </div>
      <h3 class="font-display font-bold text-xl text-forest-950 mb-5 tracking-tight">Ứng dụng</h3>
      <ul class="space-y-3 text-sm text-forest-800">
        <% product.applications.forEach(function(a) { %>
          <li class="flex items-start gap-2.5">
            <svg class="w-5 h-5 text-forest-700 mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
            <span><%= a %></span>
          </li>
        <% }); %>
      </ul>
    </div>

    <div class="bg-white rounded-2xl p-7 border border-cream-200">
      <div class="w-12 h-12 rounded-xl bg-forest-700 text-white flex items-center justify-center mb-5">
        <svg class="w-6 h-6" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z"/></svg>
      </div>
      <h3 class="font-display font-bold text-xl text-forest-950 mb-5 tracking-tight">Ưu điểm</h3>
      <ul class="space-y-3 text-sm text-forest-800">
        <% product.advantages.forEach(function(a) { %>
          <li class="flex items-start gap-2.5">
            <span class="text-earth-500 mt-0.5 flex-shrink-0">★</span>
            <span><%= a %></span>
          </li>
        <% }); %>
      </ul>
    </div>
  </div>
</section>

<!-- Bang gia -->
<section class="py-16 md:py-20 bg-cream-50">
  <div class="max-w-5xl mx-auto px-4">
    <div class="text-center mb-10">
      <div class="text-earth-700 font-semibold uppercase tracking-[0.2em] text-xs mb-3">Bảng giá</div>
      <h2 class="font-display font-bold text-3xl sm:text-4xl text-forest-950 tracking-tight">Giá <%= product.name.toLowerCase() %></h2>
      <p class="text-sm text-forest-600 mt-3">Giá có thể thay đổi theo số lượng và vị trí giao. Vui lòng gọi hotline để có giá chính xác.</p>
    </div>

    <div class="bg-white rounded-2xl overflow-hidden border border-cream-200 shadow-soft">
      <div class="overflow-x-auto">
        <table class="w-full text-sm sm:text-base">
          <thead class="bg-forest-950 text-white text-left">
            <tr>
              <th class="px-4 sm:px-6 py-4 font-semibold">Loại</th>
              <th class="px-4 sm:px-6 py-4 font-semibold">Quy cách</th>
              <th class="px-4 sm:px-6 py-4 font-semibold">Đơn vị</th>
              <th class="px-4 sm:px-6 py-4 font-semibold text-right">Giá</th>
            </tr>
          </thead>
          <tbody>
            <% product.pricing.forEach(function(row, i) { %>
              <tr class="<%= i % 2 ? 'bg-cream-50' : '' %> border-b border-cream-200 last:border-0">
                <td class="px-4 sm:px-6 py-4 font-semibold text-forest-950"><%= row.type %></td>
                <td class="px-4 sm:px-6 py-4 text-forest-700"><%= row.size %></td>
                <td class="px-4 sm:px-6 py-4 text-forest-700"><%= row.unit %></td>
                <td class="px-4 sm:px-6 py-4 text-right">
                  <a href="tel:<%= company.hotline %>" class="inline-flex items-center gap-1.5 text-earth-700 font-bold hover:text-earth-800">
                    <%= row.note %>
                    <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20"><path d="M2 3a1 1 0 011-1h2.153a1 1 0 01.986.836l.74 4.435a1 1 0 01-.54 1.06l-1.548.773a11.037 11.037 0 006.105 6.105l.774-1.548a1 1 0 011.059-.54l4.435.74a1 1 0 01.836.986V17a1 1 0 01-1 1h-2C7.82 18 2 12.18 2 5V3z"/></svg>
                  </a>
                </td>
              </tr>
            <% }); %>
          </tbody>
        </table>
      </div>
    </div>

    <div class="mt-6 bg-white border border-earth-200 rounded-2xl p-5 text-sm text-forest-800">
      <strong class="text-forest-950">Lưu ý:</strong> Bảng giá trên mang tính tham khảo. Giá thực tế phụ thuộc vào số lượng, kích thước cụ thể, vị trí giao hàng và thời điểm đặt hàng. Liên hệ hotline <a href="tel:<%= company.hotline %>" class="text-earth-700 font-semibold underline"><%= company.hotlineDisplay %></a> để nhận báo giá chính xác trong vòng 30 phút.
    </div>
  </div>
</section>

<!-- Gallery -->
<% if (product.gallery && product.gallery.length) { %>
<section class="py-16 md:py-20">
  <div class="max-w-7xl mx-auto px-4">
    <div class="text-center mb-10">
      <div class="text-earth-700 font-semibold uppercase tracking-[0.2em] text-xs mb-3">Hình ảnh</div>
      <h2 class="font-display font-bold text-3xl sm:text-4xl text-forest-950 tracking-tight">Hình ảnh thực tế</h2>
    </div>
    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4 md:gap-5">
      <% product.gallery.forEach(function(img) { %>
        <div class="aspect-[4/3] rounded-2xl overflow-hidden cursor-pointer shadow-soft hover:shadow-lifted transition" data-lightbox="<%= img %>">
          <img src="<%= img %>" alt="<%= product.name %>" loading="lazy" class="w-full h-full object-cover hover:scale-105 transition duration-500">
        </div>
      <% }); %>
    </div>
  </div>
</section>
<% } %>

<!-- CTA -->
<section class="py-16 md:py-20 bg-forest-950 text-white relative overflow-hidden">
  <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_center,rgba(212,146,41,0.15),transparent_70%)]"></div>
  <div class="relative max-w-4xl mx-auto px-4 text-center">
    <h2 class="font-display font-bold text-3xl sm:text-4xl tracking-tight mb-4">Cần báo giá chi tiết cho <%= product.name.toLowerCase() %>?</h2>
    <p class="text-cream-200 mb-8 text-sm sm:text-base">Gửi thông tin công trình, chúng tôi báo giá trong vòng 30 phút.</p>
    <div class="flex flex-col sm:flex-row gap-3 justify-center">
      <a href="tel:<%= company.hotline %>" class="inline-flex items-center justify-center gap-2 bg-earth-500 hover:bg-earth-600 text-white px-7 py-3.5 rounded-xl font-semibold shadow-soft transition">
        Gọi <%= company.hotlineDisplay %>
      </a>
      <a href="/lien-he?product=<%= product.slug %>" class="inline-flex items-center justify-center gap-2 bg-white/10 hover:bg-white/15 border border-white/20 text-white px-7 py-3.5 rounded-xl font-semibold transition backdrop-blur">
        Gửi yêu cầu báo giá
      </a>
    </div>
  </div>
</section>

<%- include('../partials/foot') %>

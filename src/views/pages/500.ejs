<%- include('../partials/head') %>
<section class="py-20 md:py-32 text-center">
  <div class="max-w-xl mx-auto px-4">
    <div class="font-display font-bold text-7xl sm:text-9xl text-red-600 mb-4">500</div>
    <h1 class="font-display font-bold text-2xl sm:text-3xl text-forest-900 mb-3">Có lỗi xảy ra</h1>
    <p class="text-forest-700 mb-8">Máy chủ gặp sự cố. Vui lòng thử lại sau hoặc gọi hotline <strong class="text-earth-700"><%= company.hotlineDisplay %></strong>.</p>
    <a href="/" class="inline-flex items-center gap-2 bg-forest-700 hover:bg-forest-800 text-white px-6 py-3 rounded-md font-semibold transition">Về trang chủ</a>
    <% if (error) { %>
      <pre class="mt-8 p-4 bg-red-50 text-red-900 text-xs text-left rounded-lg overflow-auto"><%= error.stack %></pre>
    <% } %>
  </div>
</section>
<%- include('../partials/foot') %>

<%- include('../partials/head') %>
<%- include('../partials/page-hero', { pageTitle: 'Liên hệ - Yêu cầu báo giá', pageSubtitle: 'Để lại thông tin, chúng tôi sẽ liên hệ và báo giá trong vòng 30 phút' }) %>

<section class="py-16 md:py-20">
  <div class="max-w-6xl mx-auto px-4 grid lg:grid-cols-5 gap-8">
    <!-- Form -->
    <div class="lg:col-span-3">
      <div class="bg-white rounded-3xl p-6 sm:p-8 lg:p-10 border border-cream-200 shadow-soft">
        <% if (success) { %>
          <div class="mb-6 bg-forest-50 border border-forest-200 text-forest-800 rounded-xl p-4 flex items-start gap-3">
            <svg class="w-5 h-5 flex-shrink-0 mt-0.5 text-forest-700" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
            <div>
              <div class="font-semibold">Đã gửi yêu cầu thành công!</div>
              <div class="text-sm mt-1">Cảm ơn bạn. Chúng tôi sẽ liên hệ trong thời gian sớm nhất.</div>
            </div>
          </div>
        <% } %>

        <h2 class="font-display font-bold text-2xl sm:text-3xl text-forest-950 tracking-tight mb-2">Gửi yêu cầu báo giá</h2>
        <p class="text-sm text-forest-600 mb-7">Các trường có dấu <span class="text-red-600">*</span> là bắt buộc.</p>

        <form method="POST" action="/lien-he" class="space-y-5">
          <input type="text" name="website" tabindex="-1" autocomplete="off" class="hidden" aria-hidden="true">

          <div class="grid sm:grid-cols-2 gap-4">
            <div>
              <label class="block text-sm font-semibold text-forest-950 mb-2">Họ và tên <span class="text-red-600">*</span></label>
              <input type="text" name="name" required maxlength="100" class="w-full px-4 py-3 rounded-xl border border-cream-300 focus:border-forest-500 focus:ring-2 focus:ring-forest-500/20 outline-none transition" placeholder="Nguyễn Văn A">
            </div>
            <div>
              <label class="block text-sm font-semibold text-forest-950 mb-2">Số điện thoại <span class="text-red-600">*</span></label>
              <input type="tel" name="phone" required pattern="[\d\s+\-().]{8,20}" maxlength="30" class="w-full px-4 py-3 rounded-xl border border-cream-300 focus:border-forest-500 focus:ring-2 focus:ring-forest-500/20 outline-none transition" placeholder="0909 xxx xxx">
            </div>
          </div>

          <div>
            <label class="block text-sm font-semibold text-forest-950 mb-2">Email</label>
            <input type="email" name="email" maxlength="100" class="w-full px-4 py-3 rounded-xl border border-cream-300 focus:border-forest-500 focus:ring-2 focus:ring-forest-500/20 outline-none transition" placeholder="email@example.com">
          </div>

          <div class="grid sm:grid-cols-2 gap-4">
            <div>
              <label class="block text-sm font-semibold text-forest-950 mb-2">Sản phẩm quan tâm</label>
              <select name="product" class="w-full px-4 py-3 rounded-xl border border-cream-300 focus:border-forest-500 focus:ring-2 focus:ring-forest-500/20 outline-none transition bg-white">
                <option value="">— Chọn sản phẩm —</option>
                <% products.forEach(function(p) { %>
                  <option value="<%= p.slug %>" <%= selectedProduct === p.slug ? 'selected' : '' %>><%= p.name %></option>
                <% }); %>
                <option value="khac" <%= selectedProduct === 'khac' ? 'selected' : '' %>>Khác</option>
              </select>
            </div>
            <div>
              <label class="block text-sm font-semibold text-forest-950 mb-2">Số lượng / quy cách</label>
              <input type="text" name="quantity" maxlength="100" class="w-full px-4 py-3 rounded-xl border border-cream-300 focus:border-forest-500 focus:ring-2 focus:ring-forest-500/20 outline-none transition" placeholder="VD: 500 cây 4m">
            </div>
          </div>

          <div>
            <label class="block text-sm font-semibold text-forest-950 mb-2">Mô tả công trình / yêu cầu thêm</label>
            <textarea name="message" rows="4" maxlength="2000" class="w-full px-4 py-3 rounded-xl border border-cream-300 focus:border-forest-500 focus:ring-2 focus:ring-forest-500/20 outline-none transition resize-none" placeholder="Địa chỉ giao hàng, ngày cần nhận, các yêu cầu khác..."></textarea>
          </div>

          <button type="submit" class="w-full sm:w-auto inline-flex items-center justify-center gap-2 bg-forest-900 hover:bg-forest-950 text-white px-8 py-3.5 rounded-xl font-semibold shadow-soft transition">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
            Gửi yêu cầu báo giá
          </button>
        </form>
      </div>
    </div>

    <!-- Thong tin lien he -->
    <div class="lg:col-span-2 space-y-4">
      <div class="bg-forest-950 text-white rounded-3xl p-6 md:p-8 relative overflow-hidden">
        <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_top_right,rgba(212,146,41,0.15),transparent_60%)]"></div>
        <div class="relative">
          <h3 class="font-display font-bold text-xl mb-6 tracking-tight">Liên hệ trực tiếp</h3>
          <div class="space-y-5 text-sm">
            <a href="tel:<%= company.hotline %>" class="flex items-start gap-3 hover:text-earth-300 transition group">
              <div class="w-10 h-10 rounded-xl bg-earth-500/20 flex items-center justify-center flex-shrink-0 group-hover:bg-earth-500/30 transition">
                <svg class="w-5 h-5 text-earth-400" fill="currentColor" viewBox="0 0 20 20"><path d="M2 3a1 1 0 011-1h2.153a1 1 0 01.986.836l.74 4.435a1 1 0 01-.54 1.06l-1.548.773a11.037 11.037 0 006.105 6.105l.774-1.548a1 1 0 011.059-.54l4.435.74a1 1 0 01.836.986V17a1 1 0 01-1 1h-2C7.82 18 2 12.18 2 5V3z"/></svg>
              </div>
              <div>
                <div class="text-cream-300 text-[10px] uppercase tracking-[0.18em] font-semibold">Hotline</div>
                <div class="font-bold text-base"><%= company.hotlineDisplay %></div>
              </div>
            </a>
            <a href="mailto:<%= company.email %>" class="flex items-start gap-3 hover:text-earth-300 transition group">
              <div class="w-10 h-10 rounded-xl bg-earth-500/20 flex items-center justify-center flex-shrink-0 group-hover:bg-earth-500/30 transition">
                <svg class="w-5 h-5 text-earth-400" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
              </div>
              <div>
                <div class="text-cream-300 text-[10px] uppercase tracking-[0.18em] font-semibold">Email</div>
                <div class="font-semibold break-all"><%= company.email %></div>
              </div>
            </a>
            <div class="flex items-start gap-3">
              <div class="w-10 h-10 rounded-xl bg-earth-500/20 flex items-center justify-center flex-shrink-0">
                <svg class="w-5 h-5 text-earth-400" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
              </div>
              <div>
                <div class="text-cream-300 text-[10px] uppercase tracking-[0.18em] font-semibold">Địa chỉ</div>
                <div><%= company.address %></div>
              </div>
            </div>
            <a href="https://zalo.me/<%= company.zalo %>" target="_blank" rel="noopener" class="flex items-start gap-3 hover:text-earth-300 transition group">
              <div class="w-10 h-10 rounded-xl bg-earth-500/20 flex items-center justify-center flex-shrink-0 group-hover:bg-earth-500/30 transition">
                <svg class="w-5 h-5 text-earth-400" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2C6.486 2 2 5.928 2 10.755c0 2.756 1.476 5.214 3.785 6.829v3.103c0 .328.394.49.621.255l2.27-2.358c1.06.282 2.182.43 3.324.43 5.514 0 10-3.928 10-8.755S17.514 2 12 2z"/></svg>
              </div>
              <div>
                <div class="text-cream-300 text-[10px] uppercase tracking-[0.18em] font-semibold">Zalo</div>
                <div class="font-semibold">Chat ngay với tư vấn viên</div>
              </div>
            </a>
          </div>
        </div>
      </div>

      <div class="bg-white rounded-3xl p-6 md:p-8 border border-cream-200">
        <h3 class="font-display font-bold text-base text-forest-950 mb-4 tracking-tight">Giờ làm việc</h3>
        <div class="text-sm text-forest-700 space-y-2">
          <div class="flex justify-between"><span>Thứ 2 - Thứ 7</span><span class="font-semibold text-forest-950">7:00 - 18:00</span></div>
          <div class="flex justify-between"><span>Chủ nhật</span><span class="font-semibold text-forest-950">8:00 - 12:00</span></div>
        </div>
        <p class="text-xs text-forest-600 mt-4 pt-4 border-t border-cream-200">Hotline tiếp nhận 24/7 cho công trình khẩn cấp.</p>
      </div>
    </div>
  </div>
</section>

<%- include('../partials/foot') %>

<div class="bg-forest-950 text-cream-100 text-xs sm:text-sm">
  <div class="max-w-7xl mx-auto px-4 py-2 flex flex-wrap items-center justify-between gap-x-5 gap-y-1">
    <div class="flex items-center gap-x-5 gap-y-1 flex-wrap">
      <% company.hotlines.forEach(function(h, i) { %>
        <a href="tel:<%= h.number %>" class="flex items-center gap-1.5 hover:text-earth-300 transition">
          <svg class="w-4 h-4 text-earth-400" fill="currentColor" viewBox="0 0 20 20"><path d="M2 3a1 1 0 011-1h2.153a1 1 0 01.986.836l.74 4.435a1 1 0 01-.54 1.06l-1.548.773a11.037 11.037 0 006.105 6.105l.774-1.548a1 1 0 011.059-.54l4.435.74a1 1 0 01.836.986V17a1 1 0 01-1 1h-2C7.82 18 2 12.18 2 5V3z"/></svg>
          <% if (h.name) { %><span class="text-cream-300"><%= h.name %>:</span><% } %>
          <span class="font-semibold"><%= h.display %></span>
        </a>
      <% }); %>
      <a href="mailto:<%= company.email %>" class="hidden md:flex items-center gap-1.5 hover:text-earth-300 transition">
        <svg class="w-4 h-4 text-earth-400" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
        <span><%= company.email %></span>
      </a>
    </div>
    <div class="hidden lg:flex items-center gap-1.5 text-cream-200">
      <svg class="w-4 h-4 text-earth-400" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
      <span><%= company.address %></span>
    </div>
  </div>
</div>

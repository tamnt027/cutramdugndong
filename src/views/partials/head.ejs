<!DOCTYPE html>
<html lang="vi">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= typeof title !== 'undefined' && title ? title + ' | ' + company.name : company.name + ' - Cừ tràm, Cừ bạch đàn, Cừ dừa, Lá dừa nước' %></title>
  <meta name="description" content="<%= typeof description !== 'undefined' && description ? description : 'Chuyên cung cấp cừ tràm, cừ bạch đàn, cừ dừa, lá dừa nước cho công trình tại TP.HCM, Bình Dương, Long An, Đồng Nai. Hơn 20 năm kinh nghiệm. Giá cạnh tranh, giao hàng tận nơi.' %>">
  <meta name="keywords" content="cừ tràm, cừ bạch đàn, cừ dừa, lá dừa nước, gia cố nền móng, kè bờ kênh, bán cừ tràm tphcm, công ty dũng đông">
  <meta name="robots" content="index, follow">
  <link rel="canonical" href="<%= siteUrl + currentPath %>">

  <meta property="og:type" content="website">
  <meta property="og:title" content="<%= typeof title !== 'undefined' && title ? title : company.name %>">
  <meta property="og:description" content="<%= typeof description !== 'undefined' && description ? description : 'Chuyên cung cấp cừ tràm và các loại cừ xây dựng. Hơn 20 năm kinh nghiệm.' %>">
  <meta property="og:url" content="<%= siteUrl + currentPath %>">
  <meta property="og:image" content="<%= typeof ogImage !== 'undefined' && ogImage ? ogImage : siteUrl + '/img/og-default.svg' %>">
  <meta property="og:locale" content="vi_VN">
  <meta name="twitter:card" content="summary_large_image">

  <link rel="icon" type="image/svg+xml" href="/img/favicon.svg">

  <script src="https://cdn.tailwindcss.com?plugins=typography,forms"></script>
  <script>
    tailwind.config = {
      theme: {
        extend: {
          colors: {
            // Forest: deep emerald-tinted green - modern, clean, premium
            forest: { 50:'#f0f9f4',100:'#dcefe1',200:'#bbdec7',300:'#8cc4a4',400:'#5ea27d',500:'#3f855f',600:'#2e6a4a',700:'#26553c',800:'#204432',900:'#1b382b',950:'#0d1f17' },
            // Earth: warm amber/champagne gold - modern accent
            earth:  { 50:'#fdfaf3',100:'#faf0d9',200:'#f4dfaa',300:'#ecc775',400:'#e3ad48',500:'#d49229',600:'#b8761f',700:'#94591c',800:'#79471d',900:'#653b1c',950:'#391d0c' },
            // Cream: warm stone neutral - off-white background
            cream:  { 50:'#fafaf8',100:'#f4f3ee',200:'#e8e6dd',300:'#d4d0c1',500:'#8b8678' }
          },
          fontFamily: {
            display: ['"Fraunces"', 'Georgia', 'serif'],
            sans: ['"Plus Jakarta Sans"', 'Inter', 'system-ui', 'sans-serif']
          },
          boxShadow: {
            'soft': '0 1px 2px 0 rgb(13 31 23 / 0.04), 0 4px 16px -4px rgb(13 31 23 / 0.06)',
            'lifted': '0 8px 24px -8px rgb(13 31 23 / 0.12), 0 2px 6px -2px rgb(13 31 23 / 0.06)',
          }
        }
      }
    }
  </script>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&family=Fraunces:opsz,wght@9..144,500;9..144,600;9..144,700;9..144,800&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/site.css">

  <% if (typeof structuredData !== 'undefined' && structuredData) { %>
    <script type="application/ld+json"><%- JSON.stringify(structuredData) %></script>
  <% } %>
</head>
<body class="bg-cream-50 text-forest-950 font-sans antialiased">
  <%- include('topbar') %>
  <%- include('header') %>

  <% if (flash) { %>
    <div class="bg-forest-700 text-cream-50 text-center py-2 text-sm font-medium">
      <%= flash.message %>
    </div>
  <% } %>

  <main>

# --- App ---
NODE_ENV=production
PORT=3000
SITE_URL=https://your-app.onrender.com
SESSION_SECRET=change-this-to-a-long-random-string

# --- Admin (login admin /admin/login) ---
ADMIN_USERNAME=admin
# Mat khau dang nhap admin (de plain o day, server tu hash khi so sanh)
ADMIN_PASSWORD=change-this-strong-password

# --- Database: Turso (libSQL) ---
# Dang ky free tai https://turso.tech -> tao database -> copy URL + token
# Neu de trong, app se dung SQLite local file (chi dung de dev, Render free se mat data khi restart)
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=

# --- Cloudinary (upload anh) ---
# Dang ky free tai https://cloudinary.com -> Dashboard copy 3 gia tri
# Neu de trong, admin se khong upload duoc anh
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# --- Email thong bao khi co yeu cau bao gia (tuy chon) ---
# Co the bo qua, yeu cau bao gia van luu trong DB
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
MAIL_FROM=Cu Tram Dung Dong <noreply@cutram.com>
MAIL_TO=congtydungdong@gmail.com

